    {
      "start": 0.0,
      "end": 3.4,
      "text": "Sin comunicación, no llegaréis a ningún lado."
    },
    {
      "start": 3.4,
      "end": 8.2,
      "text": "Vuestro objetivo será mantener pulsados los botones correctos durante 3 segundos."
    },
    {
      "start": 8.2,
      "end": 11.4,
      "text": "Para lograrlo, solo utilizaréis los terminales."
    },
    {
      "start": 11.4,
      "end": 15.0,
      "text": "En pantalla aparecerán muchas bolas de distintos colores."
    },
    {
      "start": 15.0,
      "end": 18.2,
      "text": "Cada bola representa un botón de ese mismo color."
    },
    {
      "start": 18.2,
      "end": 21.8,
      "text": "Tendréis que organizaros rápido y coordinaros entre todos."
    },
    {
      "start": 21.8,
      "end": 24.8,
      "text": "Cuando todos los colores correctos estén pulsados,"
    },
    {
      "start": 24.8,
      "end": 26.8,
      "text": "comenzará la cuenta atrás."
    },
    {
      "start": 26.8,
      "end": 29.6,
      "text": "Si alguien falla o se suelta antes de tiempo,"
    },
    {
      "start": 29.6,
      "end": 31.4,
      "text": "tendréis que empezar de nuevo."
    },
    {
      "start": 31.4,
      "end": 34.4,
      "text": "Pensad rápido, coordinad posiciones,"
    },
    {
      "start": 34.4,
      "end": 35.788,
      "text": "y resistid juntos."
    }
