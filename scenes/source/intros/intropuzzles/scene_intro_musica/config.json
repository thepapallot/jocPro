  "subtitles": [
    {
      "start": 0.0,
      "end": 4.16,
      "text": "Escuchad con atención: no todo se resuelve con la vista."
    },
    {
      "start": 4.16,
      "end": 8.56,
      "text": "Vuestro objetivo será reconstruir correctamente una secuencia musical."
    },
    {
      "start": 8.56,
      "end": 13.24,
      "text": "Para lograrlo, utilizaréis los tokens y los botones de los terminales."
    },
    {
      "start": 13.24,
      "end": 17.24,
      "text": "Al comenzar cada fase, escucharéis un fragmento de canción."
    },
    {
      "start": 17.24,
      "end": 20.8,
      "text": "Después deberéis reproducir ese mismo fragmento,"
    },
    {
      "start": 20.8,
      "end": 23.24,
      "text": "pasando los tokens por los terminales."
    },
    {
      "start": 23.24,
      "end": 26.96,
      "text": "Podréis volver a escucharlo tantas veces como necesitéis."
    },
    {
      "start": 26.96,
      "end": 29.84,
      "text": "Cuando creáis haber encontrado la secuencia correcta,"
    },
    {
      "start": 29.84,
      "end": 31.44,
      "text": "tendréis que registrarla."
    },
    {
      "start": 31.44,
      "end": 34.56,
      "text": "Con los botones podréis escuchar, registrar"
    },
    {
      "start": 34.56,
      "end": 36.16,
      "text": "o borrar una secuencia."
    },
    {
      "start": 36.16,
      "end": 38.16,
      "text": "Esta prueba tiene dos fases."
    },
    {
      "start": 38.16,
      "end": 39.52,
      "text": "Afinad el oído."
    },
    {
      "start": 39.52,
      "end": 41.247,
      "text": "La música comienza ya."
    }
  ],
