  "subtitles": [
    {
      "start": 0.0,
      "end": 3.7,
      "text": "La mente falla cuando más se la necesita."
    },
    {
      "start": 3.7,
      "end": 7.2,
      "text": "Vuestro objetivo será recordar letras griegas y colores."
    },
    {
      "start": 7.2,
      "end": 12.2,
      "text": "Para lograrlo usaréis vuestros tokens, los terminales y los botones."
    },
    {
      "start": 12.2,
      "end": 15.9,
      "text": "Al comenzar, veréis en pantalla los números de vuestros tokens."
    },
    {
      "start": 15.9,
      "end": 18.7,
      "text": "Observad bien, porque desaparecerán."
    },
    {
      "start": 18.7,
      "end": 22.5,
      "text": "Y en su lugar aparecerá una letra griega de un color determinado."
    },
    {
      "start": 22.5,
      "end": 25.8,
      "text": "Llevad vuestro token al terminal con esa misma letra."
    },
    {
      "start": 25.8,
      "end": 28.7,
      "text": "Después pulsad el botón del mismo color."
    },
    {
      "start": 28.9,
      "end": 33.3,
      "text": "Si una sola persona se equivoca, la fase se reiniciará."
    },
    {
      "start": 33.3,
      "end": 36.7,
      "text": "Parece sencillo, solo al principio."
    },
    {
      "start": 36.7,
      "end": 39.5,
      "text": "Cada nueva fase exigirá recordar más."
    },
    {
      "start": 39.5,
      "end": 40.281,
      "text": "Buena suerte."
    }
  ],
