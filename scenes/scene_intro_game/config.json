{
  "scene_id": "scene_intro_game",
  "description": "Intro general del juego con formato de briefing, audio actualizado y paneles de UI sincronizados con la locucion.",
  "ui_titles": {
    "top": "BRIEFING",
    "left": "RECURSOS",
